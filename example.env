# Set-CostCentreMembership.ps1 settings.
# Provide GitHub Enterprise connection details and credentials via environment variables. See .env.example for reference.
GITHUB_ENTERPRISE=my-gh-enterprise
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN=your_github_token

# Export-EntraGroupToCsv.ps1 settings.
# Provide either AZURE_ACCESS_TOKEN (a pre-acquired Graph token)
# OR the AZURE_TENANT_ID / AZURE_CLIENT_ID / AZURE_CLIENT_SECRET trio
# for the app-only client-credentials flow.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-client-secret
# AZURE_ACCESS_TOKEN=eyJ0eXAiOiJKV1Qi...
# GRAPH_BASE_URL=https://graph.microsoft.com/v1.0